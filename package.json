{
  "name": "qr-code-generator",
  "version": "0.1.0",
  "description": "Offline QR code generator, packaged as a Windows desktop app.",
  "main": "electron/main.js",
  "scripts": {
    "test": "esbuild test/decode-test.js --bundle --format=iife --outfile=test/decode-test-bundle.js",
    "build": "node build.mjs",
    "start": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win",
    "package:win": "npm run build && electron-packager . \"QR Code Generator\" --platform=win32 --arch=x64 --out=release --overwrite --icon=build/icon.ico"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "esbuild": "^0.28.1",
    "qr-code-styling": "^1.9.2"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0"
  },
  "build": {
    "appId": "com.romeomont.qrcodegenerator",
    "productName": "QR Code Generator",
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "uninstallDisplayName": "${productName}",
      "license": "build/privacy-notice.txt",
      "artifactName": "QR Code Generator Installer.exe",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "include": "build/installer.nsh",
      "warningsAsErrors": false
    }
  }
}
